#include "resource.h"
#include "afxres.h"
#pragma code_page(65001)

IDD_KEYBOARDCLICKER_DIALOG DIALOGEX 0, 0, 430, 238
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_VISIBLE | WS_CAPTION | WS_SYSMENU
EXSTYLE WS_EX_APPWINDOW
CAPTION "键盘连点器"
FONT 9, "MS Shell Dlg"
BEGIN
    LTEXT           "目标句柄:",IDC_STATIC,18,18,62,10
    EDITTEXT        IDC_TARGET_HWND,86,15,148,14,ES_AUTOHSCROLL | ES_READONLY
    LTEXT           "鼠标移到目标窗口/控件上，然后按 F9 获取句柄。",IDC_STATIC,245,18,208,10
    LTEXT           "窗口标题:",IDC_STATIC,18,41,62,10
    EDITTEXT        IDC_TARGET_TITLE,86,38,330,14,ES_AUTOHSCROLL | ES_READONLY

    LTEXT           "按键",IDC_STATIC,86,75,50,10
    LTEXT           "间隔(毫秒)",IDC_STATIC,196,75,72,10
    LTEXT           "随机偏差(毫秒):",IDC_STATIC,300,75,75,10
    EDITTEXT        IDC_RANDOM_DEVIATION,374,72,42,16,ES_AUTOHSCROLL | ES_NUMBER

    LTEXT           "组合 1:",IDC_STATIC,18,96,48,10
    EDITTEXT        IDC_KEY1,86,93,84,16,ES_AUTOHSCROLL | ES_READONLY
    EDITTEXT        IDC_INTERVAL1,196,93,84,16,ES_AUTOHSCROLL | ES_NUMBER

    LTEXT           "组合 2:",IDC_STATIC,18,123,48,10
    EDITTEXT        IDC_KEY2,86,120,84,16,ES_AUTOHSCROLL | ES_READONLY
    EDITTEXT        IDC_INTERVAL2,196,120,84,16,ES_AUTOHSCROLL | ES_NUMBER

    LTEXT           "组合 3:",IDC_STATIC,18,150,48,10
    EDITTEXT        IDC_KEY3,86,147,84,16,ES_AUTOHSCROLL | ES_READONLY
    EDITTEXT        IDC_INTERVAL3,196,147,84,16,ES_AUTOHSCROLL | ES_NUMBER

    PUSHBUTTON      "开始",IDC_START,300,104,70,24
    PUSHBUTTON      "停止",IDC_STOP,300,136,70,24

    LTEXT           "就绪。",IDC_STATUS,18,206,398,10
END
