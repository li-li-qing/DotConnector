#include "resource.h"
#include "afxres.h"
#pragma code_page(65001)

IDD_KEYBOARDCLICKER_DIALOG DIALOGEX 0, 0, 620, 520
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_VISIBLE | WS_CAPTION | WS_SYSMENU | WS_MINIMIZEBOX | WS_MAXIMIZEBOX | WS_THICKFRAME
EXSTYLE WS_EX_APPWINDOW
CAPTION "Fairy"
FONT 9, "MS Shell Dlg"
BEGIN
    GROUPBOX        "目标窗口",IDC_TARGET_GROUP,12,8,496,54
    LTEXT           "目标句柄:",IDC_TARGET_HWND_LABEL,22,27,58,10
    EDITTEXT        IDC_TARGET_HWND,86,15,148,14,ES_AUTOHSCROLL | ES_READONLY
    LTEXT           "鼠标移到目标窗口/控件上，然后按 F9 获取句柄。",IDC_TARGET_HINT,245,18,208,10
    LTEXT           "窗口标题:",IDC_TARGET_TITLE_LABEL,22,45,58,10
    EDITTEXT        IDC_TARGET_TITLE,86,38,330,14,ES_AUTOHSCROLL | ES_READONLY

    GROUPBOX        "自动按键",IDC_CLICK_GROUP,12,68,496,142
    PUSHBUTTON      "添加",IDC_ADD_CLICK_ACTION,540,84,50,20
    PUSHBUTTON      "减少",IDC_REMOVE_CLICK_ACTION,602,84,50,20
    LTEXT           "#",IDC_CLICK_INDEX_HEADER,24,112,14,10
    LTEXT           "按键",IDC_CLICK_KEY_HEADER,52,112,36,10
    LTEXT           "间隔(毫秒)",IDC_CLICK_INTERVAL_HEADER,122,112,62,10
    LTEXT           "#",IDC_CLICK_INDEX_HEADER_2,260,112,14,10
    LTEXT           "按键",IDC_CLICK_KEY_HEADER_2,288,112,36,10
    LTEXT           "间隔(毫秒)",IDC_CLICK_INTERVAL_HEADER_2,358,112,62,10
    LTEXT           "随机偏差(毫秒):",IDC_RANDOM_DEVIATION_LABEL,382,246,78,10
    EDITTEXT        IDC_RANDOM_DEVIATION,464,243,50,16,ES_AUTOHSCROLL | ES_NUMBER
    PUSHBUTTON      "开始",IDC_START,532,238,54,24
    PUSHBUTTON      "停止",IDC_STOP,598,238,54,24

    GROUPBOX        "喊话动作",IDC_SHOUT_GROUP,12,220,496,150
    PUSHBUTTON      "添加一条",IDC_ADD_SHOUT_ACTION,590,299,62,20
    PUSHBUTTON      "减少一条",IDC_REMOVE_SHOUT_ACTION,516,299,62,20
    LTEXT           "#",IDC_SHOUT_INDEX_HEADER,24,322,14,10
    LTEXT           "触发键",IDC_SHOUT_KEY_HEADER,48,322,40,10
    LTEXT           "次数",IDC_SHOUT_COUNT_HEADER,104,322,26,10
    LTEXT           "间隔",IDC_SHOUT_DELAY_HEADER,144,322,26,10
    LTEXT           "团队消息",IDC_SHOUT_MESSAGE_HEADER,192,322,50,10
    LTEXT           "技能前等",IDC_SHOUT_WAIT_HEADER,382,322,48,10
    LTEXT           "报点后序列",IDC_SHOUT_SEQUENCE_HEADER,442,322,62,10
    LTEXT           "冷却补按",IDC_SHOUT_COOLDOWN_HEADER,592,322,50,10

    LTEXT           "就绪。",IDC_STATUS,18,553,420,10,SS_LEFTNOWORDWRAP | SS_ENDELLIPSIS
    GROUPBOX        "调试输出",IDC_DEBUG_GROUP,12,570,496,72
    PUSHBUTTON      "高级功能",IDC_ADVANCED_FEATURES,420,584,72,20
    PUSHBUTTON      "清空日志",IDC_CLEAR_DEBUG_LOG,340,584,72,20
    EDITTEXT        IDC_DEBUG_LOG,24,602,472,32,ES_MULTILINE | ES_AUTOVSCROLL | ES_READONLY | WS_VSCROLL | WS_HSCROLL
END

IDD_ADVANCED_PASSWORD_DIALOG DIALOGEX 0, 0, 220, 86
STYLE DS_SETFONT | DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "高级功能验证"
FONT 9, "MS Shell Dlg"
BEGIN
    LTEXT           "请输入高级功能密码:",IDC_STATIC,12,14,120,10
    EDITTEXT        IDC_ADVANCED_PASSWORD_EDIT,12,30,196,16,ES_PASSWORD | ES_AUTOHSCROLL
    DEFPUSHBUTTON   "确定",IDOK,98,58,52,18
    PUSHBUTTON      "取消",IDCANCEL,156,58,52,18
END
